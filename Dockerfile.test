# Reproducible environment for lipi's PDF + visual regression tests.
# LibreOffice does the Bengali shaping; poppler rasterizes; xmllint validates.
FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      libreoffice-writer \
      fonts-noto-core \
      fontconfig \
      poppler-utils \
      libxml2-utils \
      ca-certificates \
 && rm -rf /var/lib/apt/lists/*

RUN corepack enable

WORKDIR /app
COPY . .

RUN pnpm install --no-frozen-lockfile && pnpm build

# Belt-and-braces: install the bundled fonts so LibreOffice can also find them
# on disk, not only via the embedded odttf (BUILD_PROMPT.md §8).
RUN mkdir -p /usr/share/fonts/truetype/lipi \
 && cp packages/fonts/fonts/*.ttf /usr/share/fonts/truetype/lipi/ \
 && fc-cache -f

# Default: run the full suite + the visual regression.
CMD ["sh", "-c", "pnpm test && pnpm test:visual:local"]
